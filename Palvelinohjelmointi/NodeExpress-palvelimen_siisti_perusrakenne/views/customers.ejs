<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Customers</title>
</head>

<body>

<nav>
  <a href="/customers">Asiakkaat ja käyttäjät</a> |
  <a href="/tickets">Tukipyynnöt</a> |
  <a href="/feedback">Palaute</a>
  
</nav>

<h2>Asiakkaat ja käyttäjät</h2>

<table border="1">
  <tr>
    <th>Yritys</th>
    <th>ID</th>
    <th>Koko nimi</th>
    <th>Email</th>
    <th>Admin</th>
  </tr>

  <% for (const row of rows) { %>
    <tr>
      <td><%= row.company_name || "-" %></td>
      <td><%= row.user_id %></td>
      <td><%= row.fullname %></td>
      <td><%= row.email %></td>
      <td><%= row.admin ? "Kyllä" : "Ei" %></td>
    </tr>
  <% } %>

</table>

</body>
</html>